# MemOS-Q production ECS / Alibaba Cloud configuration
MEMOS_ENV=production
API_BASE_URL=https://api.example.com
FRONTEND_URL=https://app.example.com

# Production mode: ECS runs FastAPI, RDS stores memory records, Qwen creates
# embeddings, and OpenSearch Vector Engine stores/searches vectors.
MEMOS_STORE=alicloud
QWEN_REQUIRE_LIVE_EMBEDDINGS=true

# Qwen / DashScope Model Studio
QWEN_API_KEY=replace-with-your-dashscope-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_REASONING_MODEL=qwen3.5-plus
QWEN_FLASH_MODEL=qwen3.5-flash
QWEN_VL_MODEL=qwen3-vl-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_EMBEDDING_DIMENSIONS=1024

# Alibaba Cloud RDS PostgreSQL source of truth for memory/audit records
POSTGRES_USER=memos
POSTGRES_PASSWORD=replace-with-rds-password
POSTGRES_DB=memos
POSTGRES_DSN=postgresql://memos:replace-with-rds-password@rm-xxxx.pg.rds.aliyuncs.com:5432/memos

# Alibaba Cloud OpenSearch Vector Engine
OPENSEARCH_ENDPOINT=https://opensearch-xxxx.aliyuncs.com
OPENSEARCH_USERNAME=replace-with-opensearch-username
OPENSEARCH_PASSWORD=replace-with-opensearch-password
OPENSEARCH_INDEX=memos-q-vectors
OPENSEARCH_VECTOR_FIELD=embedding

# Redis / Celery. Use ApsaraDB for Redis in production.
REDIS_URL=redis://:replace-with-redis-password@r-xxxx.redis.rds.aliyuncs.com:6379/0
CELERY_BROKER_URL=redis://:replace-with-redis-password@r-xxxx.redis.rds.aliyuncs.com:6379/1
CELERY_RESULT_BACKEND=redis://:replace-with-redis-password@r-xxxx.redis.rds.aliyuncs.com:6379/2

# Object storage (Alibaba Cloud OSS S3-compatible endpoint or another S3-compatible bucket)
S3_ENDPOINT_URL=https://oss-cn-hangzhou.aliyuncs.com
S3_ACCESS_KEY_ID=replace-with-oss-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-oss-secret-access-key
S3_BUCKET=memos-q
S3_REGION=cn-hangzhou

# Optional observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
MEMOS_ENABLE_OTEL=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
